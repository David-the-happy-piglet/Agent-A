+                        break;
+                    }
+                    case XmlPullParser.END_TAG: {
+                        String tag = parser.getName();
+                        if ("item".equalsIgnoreCase(tag) || "entry".equalsIgnoreCase(tag)) {
+                            insideItem  = false;
+                            nextIsTitle = false;
+                        }
+                        break;
+                    }
+                }
+                eventType = parser.next();
+            }
+
+        } finally {
+            if (conn != null) conn.disconnect();
+        }
+
+        return titles;
+    }
